# ===========================================
# 家庭图书馆 - 环境变量模板
# 复制为 .env 后按需修改
# ===========================================

# 前端容器对外暴露的端口 (主机端口)
# 飞牛 NAS 改成 80:80 可以直接用 NAS IP 访问
PORT=8080

# ===== 后端配置 (在 backend/.env 或根 .env 都可读) =====

# 数据库连接 (默认 ./data/library.db, 部署到 NAS 改成绝对路径)
DATABASE_URL=sqlite+aiosqlite:///./data/library.db

# ★★★ JWT 签名密钥 - 生产环境务必改成随机长字符串 ★★★
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=please-change-me-to-a-random-string-at-least-32-chars

# Token 有效期 (分钟, 默认 7 天)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 上传文件目录
UPLOAD_DIR=./data/uploads

# 单文件最大体积 (字节, 默认 5MB)
MAX_UPLOAD_SIZE=5242880

# 豆瓣抓取超时 (秒)
META_TIMEOUT_SECONDS=10

# CORS 允许的源 (开发用 *, 生产改成具体域名)
CORS_ORIGINS=["*"]
